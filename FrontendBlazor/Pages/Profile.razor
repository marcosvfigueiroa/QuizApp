@page "/profile"
@using FrontendBlazor.Services
@inject ProfileService ProfileService
@inject TokenState Token
@inject NavigationManager Nav

<div class="page-header">
    <div class="page-header-left">
        <h1>Profile</h1>
        <p>Manage your account information and password.</p>
    </div>
</div>

@if (!Token.IsAuthenticated)
{
    <div class="alert alert-info">You must be signed in to view your profile. <a href="/login">Sign in</a></div>
}
else if (_loading)
{
    <div class="loading-state"><div class="spinner"></div><span>Loading profile...</span></div>
}
else
{
    @if (!string.IsNullOrEmpty(_successMsg))
    {
        <div class="alert alert-success">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            @_successMsg
        </div>
    }
    @if (!string.IsNullOrEmpty(_errorMsg))
    {
        <div class="alert alert-danger">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @_errorMsg
        </div>
    }

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;max-width:820px;" class="profile-grid">
        <!-- Account info card -->
        <div class="card">
            <div class="card-header">
                <span class="card-title">Account Information</span>
            </div>
            <div class="card-body">
                <div style="display:flex;align-items:center;gap:16px;margin-bottom:24px;">
                    <div style="width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,var(--brand),#8b5cf6);display:grid;place-items:center;font-size:22px;font-weight:800;color:#fff;flex-shrink:0;">
                        @(_fullName.Length > 0 ? _fullName[0].ToString().ToUpper() : "?")
                    </div>
                    <div>
                        <div style="font-weight:700;font-size:16px;">@_fullName</div>
                        <div style="font-size:13px;color:var(--text-secondary);">@_email</div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Full name</label>
                    <input class="form-control" type="text" @bind="_fullName" placeholder="Jane Doe" />
                </div>
                <div class="form-group" style="margin-bottom:0;">
                    <label class="form-label">Email address</label>
                    <input class="form-control" type="email" @bind="_email" placeholder="you@example.com" />
                </div>
            </div>
        </div>

        <!-- Password card -->
        <div class="card">
            <div class="card-header">
                <span class="card-title">Change Password</span>
            </div>
            <div class="card-body">
                <div class="form-group">
                    <label class="form-label">Current password</label>
                    <input class="form-control" type="password" @bind="_currentPassword" placeholder="••••••••" />
                </div>
                <div class="form-group" style="margin-bottom:0;">
                    <label class="form-label">New password</label>
                    <input class="form-control" type="password" @bind="_newPassword" placeholder="••••••••" />
                    <span class="form-hint">Leave blank to keep your current password.</span>
                </div>
            </div>
        </div>
    </div>

    <div style="margin-top:20px;max-width:820px;">
        <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
            @if (_saving) { <div class="spinner" style="width:14px;height:14px;border-width:2px;"></div> }
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            Save changes
        </button>
    </div>
}

<style>
    @@media (max-width: 640px) {
        .profile-grid { grid-template-columns: 1fr !important; }
    }
</style>

@code {
    private string _fullName = "";
    private string _email    = "";
    private string _currentPassword = "";
    private string _newPassword     = "";
    private string? _successMsg;
    private string? _errorMsg;
    private bool _loading = true;
    private bool _saving  = false;

    protected override async Task OnInitializedAsync()
    {
        if (!Token.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        var (ok, profile, error) = await ProfileService.GetProfileAsync();
        if (ok && profile != null) { _fullName = profile.FullName; _email = profile.Email; }
        else _errorMsg = "Could not load profile: " + error;
        _loading = false;
    }

    private async Task Save()
    {
        _saving = true; _successMsg = null; _errorMsg = null;
        var (ok, error) = await ProfileService.UpdateProfileAsync(
            _fullName, _email,
            string.IsNullOrWhiteSpace(_currentPassword) ? null : _currentPassword,
            string.IsNullOrWhiteSpace(_newPassword)     ? null : _newPassword);
        _saving = false;
        if (ok) { _successMsg = "Profile updated successfully."; _currentPassword = ""; _newPassword = ""; }
        else _errorMsg = "Could not save profile: " + error;
    }
}
