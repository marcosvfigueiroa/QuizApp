@page "/register"
@layout FrontendBlazor.Shared.MainLayout
@inject AuthService Auth
@inject NavigationManager Nav

<div class="auth-shell">
    <div class="auth-card">
        <div class="auth-logo">
            <div class="auth-logo-icon">Q</div>
            <span class="auth-logo-name">QuizApp</span>
        </div>

        <h2>Create account</h2>
        <p class="subtitle">Join QuizApp to start building and sharing quizzes.</p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="alert alert-danger">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                @_error
            </div>
        }

        <div class="form-group">
            <label class="form-label">Full name <span class="required">*</span></label>
            <input class="form-control" type="text" @bind="_fullName" placeholder="Jane Doe" />
        </div>

        <div class="form-group">
            <label class="form-label">Email <span class="required">*</span></label>
            <input class="form-control" type="email" @bind="_email" placeholder="you@example.com" />
        </div>

        <div class="form-group">
            <label class="form-label">Password <span class="required">*</span></label>
            <input class="form-control" type="password" @bind="_password" placeholder="Min. 6 characters" />
            <span class="form-hint">At least 6 characters recommended.</span>
        </div>

        <button class="btn btn-primary" style="width:100%;margin-top:4px;" @onclick="DoRegister" disabled="@_loading">
            @if (_loading) { <div class="spinner" style="width:15px;height:15px;border-width:2px;"></div> }
            Create account
        </button>

        <div class="auth-footer">
            Already have an account? <a href="/login">Sign in</a>
        </div>
    </div>
</div>

@code {
    private string _fullName = "";
    private string _email    = "";
    private string _password = "";
    private string? _error;
    private bool _loading = false;

    private async Task DoRegister()
    {
        if (string.IsNullOrWhiteSpace(_fullName) || string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            _error = "Please fill in all fields.";
            return;
        }
        _loading = true;
        _error   = null;
        var ok = await Auth.RegisterAsync(_fullName, _email, _password);
        _loading = false;
        if (ok) Nav.NavigateTo("/");
        else _error = "Registration failed. The email may already be in use.";
    }
}
