@page "/quizzes/{Id:int}/edit"
@using FrontendBlazor.Services
@inject QuizService QuizService
@inject NavigationManager Nav
@inject TokenState Token

<div class="page-header">
    <div class="page-header-left">
        <h1>@(_quiz?.Title ?? "Edit Quiz")</h1>
        <p>Add and manage questions and choices.</p>
    </div>
    <div style="display:flex;gap:8px;">
        @if (_quiz != null)
        {
            <a href="/quizzes/@_quiz.Id/preview" class="btn btn-secondary btn-sm">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                Preview
            </a>
            <a href="/quizzes/@_quiz.Id/import" class="btn btn-secondary btn-sm">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                Import
            </a>
        }
        <a href="/quizzes" class="btn btn-ghost btn-sm">← Back</a>
    </div>
</div>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger">@_errorMessage</div>
}
@if (!string.IsNullOrEmpty(_successMessage))
{
    <div class="alert alert-success">@_successMessage</div>
}

@if (!Token.IsAuthenticated)
{
    <div class="alert alert-info">Please <a href="/login">sign in</a> to edit quizzes.</div>
}
else if (_quiz == null && _loading)
{
    <div class="loading-state"><div class="spinner"></div><span>Loading quiz...</span></div>
}
else if (_quiz == null)
{
    <div class="alert alert-danger">Quiz not found.</div>
}
else
{
    <!-- Quiz meta -->
    <div class="card" style="margin-bottom:20px;">
        <div class="card-header">
            <span class="card-title">Quiz Details</span>
            <button class="btn btn-primary btn-sm" @onclick="SaveQuiz" disabled="@_savingQuiz">
                @if (_savingQuiz) { <div class="spinner" style="width:13px;height:13px;border-width:2px;"></div> }
                Save
            </button>
        </div>
        <div class="card-body">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
                <div class="form-group" style="margin-bottom:0;">
                    <label class="form-label">Title <span class="required">*</span></label>
                    <input class="form-control" type="text" @bind="_quiz.Title" placeholder="Quiz title" />
                </div>
                <div class="form-group" style="margin-bottom:0;">
                    <label class="form-label">Description</label>
                    <input class="form-control" type="text" @bind="_quiz.Description" placeholder="Optional description" />
                </div>
            </div>
        </div>
    </div>

    <!-- Questions list -->
    <div style="margin-bottom:16px;display:flex;align-items:center;justify-content:space-between;">
        <h2 style="font-size:17px;font-weight:700;">Questions <span style="font-size:13px;color:var(--text-muted);font-weight:400;">(@_quiz.Questions.Count)</span></h2>
    </div>

    @foreach (var item in _quiz.Questions.Select((q, i) => (q, i)))
    {
        var q = item.q;
        var num = item.i + 1;
        <div class="question-editor">
            <div class="qe-header">
                <div class="qe-number">@num</div>
                <span style="flex:1;font-size:13px;font-weight:600;color:var(--text-secondary);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@q.Statement</span>
                <span class="badge @GetCategoryBadge(q.Category)" style="margin-right:4px;">@GetCategoryLabel(q.Category)</span>
                <span class="badge badge-neutral">×@q.Weight</span>
                <button class="btn btn-danger btn-sm btn-icon" style="margin-left:8px;" title="Delete question" @onclick="() => DeleteQuestion(q.Id)">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                </button>
            </div>
            <div class="qe-body">
                <div class="qe-row" style="margin-bottom:14px;">
                    <div class="form-group" style="flex:3;">
                        <label class="form-label">Statement</label>
                        <input class="form-control" type="text" @bind="q.Statement" placeholder="Question text..." />
                    </div>
                    <div class="form-group" style="flex:1;">
                        <label class="form-label">Category</label>
                        <select class="form-control" @bind="q.Category">
                            <option value="0">Easy</option>
                            <option value="1">Medium</option>
                            <option value="2">Hard</option>
                        </select>
                    </div>
                    <div class="form-group" style="flex:0 0 90px;">
                        <label class="form-label">Weight</label>
                        <input class="form-control" type="number" @bind="q.Weight" min="1" max="10" />
                    </div>
                    <div style="padding-bottom:0;">
                        <button class="btn btn-secondary btn-sm" @onclick="() => SaveQuestion(q)">Save</button>
                    </div>
                </div>

                <!-- Choices -->
                <div style="margin-bottom:10px;">
                    <label class="form-label" style="margin-bottom:8px;">Choices</label>
                    @foreach (var c in q.Choices)
                    {
                        <div class="choice-editor">
                            <div class="ce-row">
                                <input class="form-control" type="text" @bind="c.Text" placeholder="Choice text..." />
                                <label class="form-check" style="white-space:nowrap;min-width:90px;">
                                    <input class="form-check-input" type="checkbox" @bind="c.IsCorrect" />
                                    <span class="form-check-label" style="color:@(c.IsCorrect ? "var(--success)" : "var(--text-secondary)");">Correct</span>
                                </label>
                                <button class="btn btn-secondary btn-sm" @onclick="() => SaveChoice(q, c)">Save</button>
                                <button class="btn btn-danger btn-sm btn-icon" title="Delete" @onclick="() => DeleteChoice(c.Id)">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                </button>
                            </div>
                        </div>
                    }

                    <!-- Add new choice -->
                    <div class="choice-editor" style="border-style:dashed;border-color:var(--border-hover);">
                        <div class="ce-row">
                            <input class="form-control" type="text"
                                   value="@GetNewChoiceText(q.Id)"
                                   @oninput="e => SetNewChoiceText(q.Id, e.Value?.ToString() ?? string.Empty)"
                                   placeholder="New choice..." />
                            <label class="form-check" style="white-space:nowrap;min-width:90px;">
                                <input class="form-check-input" type="checkbox"
                                       checked="@GetNewChoiceIsCorrect(q.Id)"
                                       @onchange="e => SetNewChoiceIsCorrect(q.Id, (bool)e.Value!)" />
                                <span class="form-check-label">Correct</span>
                            </label>
                            <button class="btn btn-primary btn-sm" @onclick="() => AddChoice(q)">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                Add
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Add new question -->
    <div class="card" style="border-style:dashed;border-color:var(--border-hover);">
        <div class="card-header">
            <span class="card-title" style="color:var(--text-secondary);">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add New Question
            </span>
        </div>
        <div class="card-body">
            <div class="qe-row" style="margin-bottom:0;">
                <div class="form-group" style="flex:3;margin-bottom:0;">
                    <label class="form-label">Statement <span class="required">*</span></label>
                    <input class="form-control" type="text" @bind="_newStatement" placeholder="Enter question..." />
                </div>
                <div class="form-group" style="flex:1;margin-bottom:0;">
                    <label class="form-label">Category</label>
                    <select class="form-control" @bind="_newCategory">
                        <option value="0">Easy</option>
                        <option value="1">Medium</option>
                        <option value="2">Hard</option>
                    </select>
                </div>
                <div class="form-group" style="flex:0 0 90px;margin-bottom:0;">
                    <label class="form-label">Weight</label>
                    <input class="form-control" type="number" @bind="_newWeight" min="1" max="10" />
                </div>
                <div style="padding-top:22px;">
                    <button class="btn btn-primary" @onclick="AddQuestion" disabled="@_addingQuestion">
                        @if (_addingQuestion) { <div class="spinner" style="width:13px;height:13px;border-width:2px;"></div> }
                        Add Question
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private QuizService.QuizDetail? _quiz;
    private bool _loading = true;
    private bool _savingQuiz = false;
    private bool _addingQuestion = false;
    private string? _errorMessage;
    private string? _successMessage;

    private string _newStatement = "";
    private int    _newCategory  = 0;
    private int    _newWeight    = 1;

    private readonly Dictionary<int, string> _newChoiceText      = new();
    private readonly Dictionary<int, bool>   _newChoiceIsCorrect = new();

    protected override async Task OnInitializedAsync()
    {
        if (!Token.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        await Load();
    }

    private async Task Load()
    {
        _loading = true; _errorMessage = null;
        _quiz = await QuizService.GetQuizAsync(Id);
        if (_quiz == null) _errorMessage = "Quiz not found.";
        _loading = false;
    }

    private async Task SaveQuiz()
    {
        if (_quiz == null) return;
        _savingQuiz = true; _errorMessage = null;
        var ok = await QuizService.UpdateQuizAsync(_quiz);
        _savingQuiz = false;
        if (ok) { _successMessage = "Quiz saved."; await Load(); }
        else _errorMessage = "Could not save quiz.";
    }

    private async Task AddQuestion()
    {
        if (_quiz == null || string.IsNullOrWhiteSpace(_newStatement)) { _errorMessage = "Please enter a question statement."; return; }
        _addingQuestion = true; _errorMessage = null;
        var id = await QuizService.AddQuestionAsync(_quiz.Id, _newStatement, _newCategory, _newWeight);
        _addingQuestion = false;
        if (!id.HasValue) { _errorMessage = "Could not add question."; return; }
        _newStatement = ""; _newCategory = 0; _newWeight = 1;
        await Load();
    }

    private async Task SaveQuestion(QuizService.Question q)
    {
        _errorMessage = null;
        var ok = await QuizService.UpdateQuestionAsync(q.Id, q.Statement, q.Category, q.Weight);
        if (ok) { _successMessage = "Question saved."; await Load(); }
        else _errorMessage = "Could not save question.";
    }

    private async Task DeleteQuestion(int id)
    {
        _errorMessage = null;
        var ok = await QuizService.DeleteQuestionAsync(id);
        if (ok) await Load(); else _errorMessage = "Could not delete question.";
    }

    private async Task AddChoice(QuizService.Question q)
    {
        var text      = GetNewChoiceText(q.Id);
        var isCorrect = GetNewChoiceIsCorrect(q.Id);
        if (string.IsNullOrWhiteSpace(text)) { _errorMessage = "Choice text cannot be empty."; return; }
        _errorMessage = null;
        var id = await QuizService.AddChoiceAsync(q.Id, text, isCorrect);
        if (!id.HasValue) { _errorMessage = "Could not add choice."; return; }
        _newChoiceText.Remove(q.Id); _newChoiceIsCorrect.Remove(q.Id);
        await Load();
    }

    private async Task SaveChoice(QuizService.Question q, QuizService.Choice c)
    {
        var ok = await QuizService.UpdateChoiceAsync(c.Id, c.Text, c.IsCorrect);
        if (ok) { _successMessage = "Choice saved."; await Load(); }
        else _errorMessage = "Could not save choice.";
    }

    private async Task DeleteChoice(int id)
    {
        var ok = await QuizService.DeleteChoiceAsync(id);
        if (ok) await Load(); else _errorMessage = "Could not delete choice.";
    }

    private string GetNewChoiceText(int qId) => _newChoiceText.TryGetValue(qId, out var t) ? t : "";
    private bool   GetNewChoiceIsCorrect(int qId) => _newChoiceIsCorrect.TryGetValue(qId, out var v) && v;
    private void   SetNewChoiceText(int qId, string t) => _newChoiceText[qId] = t;
    private void   SetNewChoiceIsCorrect(int qId, bool v) => _newChoiceIsCorrect[qId] = v;

    private string GetCategoryLabel(int cat) => cat switch { 0 => "Easy", 1 => "Medium", 2 => "Hard", _ => "?" };
    private string GetCategoryBadge(int cat)  => cat switch { 0 => "badge-success", 1 => "badge-warning", 2 => "badge-danger", _ => "badge-neutral" };
}
