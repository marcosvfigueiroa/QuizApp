@page "/quizzes"
@using FrontendBlazor.Services
@inject QuizService QuizService
@inject TokenState Token
@inject NavigationManager Nav

<div class="page-header">
    <div class="page-header-left">
        <h1>My Quizzes</h1>
        <p>Create, edit and manage all your quizzes.</p>
    </div>
    @if (Token.IsAuthenticated)
    {
        <a href="/quizzes/create" class="btn btn-primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            New Quiz
        </a>
    }
</div>

@if (!Token.IsAuthenticated)
{
    <div class="alert alert-info">Please <a href="/login">sign in</a> to manage your quizzes.</div>
}
else
{
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="alert alert-danger">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            @_errorMessage
        </div>
    }

    <div class="toolbar">
        <div class="search-bar">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input @bind="_search" @bind:event="oninput" @onkeydown="OnKeyDown" placeholder="Search quizzes..." />
        </div>
        <button class="btn btn-secondary" @onclick="Load">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            Search
        </button>
    </div>

    @if (_loading)
    {
        <div class="loading-state"><div class="spinner"></div><span>Loading quizzes...</span></div>
    }
    else if (_quizzes == null || _quizzes.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-state-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
            </div>
            <h3>No quizzes found</h3>
            <p>@(string.IsNullOrEmpty(_search) ? "Get started by creating your first quiz." : $"No results for \"{_search}\".")</p>
            @if (string.IsNullOrEmpty(_search))
            {
                <a href="/quizzes/create" class="btn btn-primary">Create Quiz</a>
            }
        </div>
    }
    else
    {
        <div class="table-wrap">
            <table>
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Questions</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var q in _quizzes)
                    {
                        <tr>
                            <td>
                                <div style="font-weight:600;">@q.Title</div>
                            </td>
                            <td>
                                <span style="color:var(--text-secondary);">@q.QuestionCount question@(q.QuestionCount != 1 ? "s" : "")</span>
                            </td>
                            <td>
                                @if (q.IsPublished)
                                {
                                    <span class="badge badge-success">
                                        <svg width="8" height="8" viewBox="0 0 8 8" fill="currentColor"><circle cx="4" cy="4" r="4"/></svg>
                                        Published
                                    </span>
                                }
                                else
                                {
                                    <span class="badge badge-neutral">Draft</span>
                                }
                            </td>
                            <td>
                                <div class="td-actions">
                                    <a href="/quizzes/@q.Id/edit" class="btn btn-secondary btn-sm">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                        Edit
                                    </a>
                                    <a href="/quizzes/@q.Id/preview" class="btn btn-ghost btn-sm">Preview</a>
                                    @if (q.IsPublished)
                                    {
                                        <a href="/quizzes/@q.Id/run" class="btn btn-primary btn-sm">Take</a>
                                        <button class="btn btn-ghost btn-sm" @onclick="() => TogglePublishAsync(q)">Unpublish</button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-success btn-sm" @onclick="() => TogglePublishAsync(q)">
                                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                            Publish
                                        </button>
                                    }
                                    <button class="btn btn-ghost btn-sm" title="Duplicate" @onclick="() => DuplicateQuizAsync(q.Id)">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                                    </button>
                                    <button class="btn btn-danger btn-sm" title="Delete" @onclick="() => DeleteQuizAsync(q.Id)">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    private List<QuizService.QuizListItem>? _quizzes;
    private string? _search;
    private string? _errorMessage;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        if (!Token.IsAuthenticated) { Nav.NavigateTo("/login"); return; }
        await Load();
    }

    private async Task Load()
    {
        _loading = true; _errorMessage = null;
        _quizzes = await QuizService.GetQuizzesAsync(_search);
        _loading = false;
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await Load();
    }

    private async Task DeleteQuizAsync(int id)
    {
        var ok = await QuizService.DeleteQuizAsync(id);
        if (!ok) _errorMessage = "Unable to delete quiz.";
        else await Load();
    }

    private async Task TogglePublishAsync(QuizService.QuizListItem quiz)
    {
        _errorMessage = null;
        var ok = quiz.IsPublished
            ? await QuizService.UnpublishAsync(quiz.Id)
            : await QuizService.PublishAsync(quiz.Id);
        if (!ok) _errorMessage = "Cannot change publish state. To publish, the quiz must have at least one question, each with ≥ 2 choices and exactly 1 correct answer.";
        else await Load();
    }

    private async Task DuplicateQuizAsync(int id)
    {
        var copy = await QuizService.DuplicateAsync(id);
        if (copy is null) _errorMessage = "Unable to duplicate quiz.";
        else await Load();
    }
}
